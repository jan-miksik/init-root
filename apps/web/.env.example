# create .env and copy these variables there
# cp .env.example .env

# Set to 'true' to preview non-localhost UI behaviour (Live agent modal, Paper default) during local dev
# NUXT_PUBLIC_SIMULATE_NON_LOCALHOST=true

# deployed `Agent.sol` address
NUXT_PUBLIC_INITIA_CONTRACT_ADDRESS=

# deployed `IUSDDemoToken` address
NUXT_PUBLIC_INITIA_SHOWCASE_TOKEN_ADDRESS= 

# deployed `IUSDDemoFaucet` address 
NUXT_PUBLIC_INITIA_SHOWCASE_TOKEN_FAUCET_ADDRESS=

# deployed `MockPerpDEX` address
NUXT_PUBLIC_INITIA_MOCK_PERP_DEX_ADDRESS=

# public address of the executor account
NUXT_PUBLIC_INITIA_EXECUTOR_ADDRESS= 

#call target used in the showcase flow. Locally this is usually the same as `MockPerpDEX`
NUXT_PUBLIC_INITIA_SHOWCASE_TARGET_ADDRESS=

NUXT_PUBLIC_INITIA_EXECUTOR_MAX_TRADE_WEI=1000000000000000000
NUXT_PUBLIC_INITIA_EXECUTOR_DAILY_LIMIT_WEI=5000000000000000000