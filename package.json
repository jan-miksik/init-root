{
  "name": "something-in-loop",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.24.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "pnpm --filter @something-in-loop/api dev",
    "dev:web": "pnpm --filter @something-in-loop/web dev",
    "build": "turbo run build",
    "build:worker": "npm run build --workspace=@something-in-loop/shared && node_modules/esbuild/bin/esbuild apps/api/src/index.ts --bundle --minify --outfile=apps/api/dist/worker.js --platform=browser --format=esm --external:cloudflare:workers",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "deploy:api": "npm run deploy --workspace=@something-in-loop/api -- --env production",
    "deploy:web": "npm run build --workspace=@something-in-loop/web && npx wrangler pages deploy apps/web/dist --project-name=init-root --commit-dirty=true"
  },
  "devDependencies": {
    "@anthropic-ai/claude-code": "^2.1.42",
    "@playwright/test": "^1.58.2",
    "turbo": "^2.0.0",
    "wrangler": "^4.65.0"
  },
  "dependencies": {
    "esbuild": "^0.27.3"
  },
  "pnpm": {
    "patchedDependencies": {
      "@initia/interwovenkit-react@2.5.1": "patches/@initia__interwovenkit-react@2.5.1.patch"
    }
  },
  "overrides": {
    "vue": "^3.4.0",
    "cosmjs-types": "0.10.1",
    "@cosmjs/amino": "0.36.2",
    "@cosmjs/crypto": "0.36.2",
    "@cosmjs/encoding": "0.36.2",
    "@cosmjs/math": "0.36.2",
    "@cosmjs/proto-signing": "0.36.2",
    "@cosmjs/stargate": "0.36.2",
    "@cosmjs/tendermint-rpc": "0.36.2",
    "@cosmjs/cosmwasm": "0.36.2",
    "@cosmjs/cosmwasm-stargate": "0.36.2"
  }
}
